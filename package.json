{
  "name": "mr1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "viz:build": "tsc --outDir .viz-build",
    "viz": "npm run viz:build && node .viz-build/index.js",
    "viz:once": "npm run viz:build && node .viz-build/index.js --once",
    "viz:test": "npm run viz:build && node --test .viz-build/timeline.test.js",
    "viz:termui": "tsx --tsconfig tsconfig.termui.json viz-termui/index.tsx",
    "viz:termui:once": "tsx --tsconfig tsconfig.termui.json viz-termui/index.tsx --once",
    "viz:termui:test": "tsx --tsconfig tsconfig.termui.json --test viz-termui/render.test.ts"
  },
  "dependencies": {
    "@termuijs/core": "^0.1.3",
    "@termuijs/jsx": "^0.1.3",
    "@termuijs/motion": "^0.1.3",
    "@termuijs/widgets": "^0.1.3",
    "ink": "^7.0.1",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
